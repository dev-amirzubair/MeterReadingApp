# Bill check URL templates — copy this file to `.env` and adjust as needed.
# `{consumer}` is replaced at runtime with the consumer number entered by
# the user. Anything else in the URL is taken verbatim.
#
# After editing `.env`, restart Metro with: `npm start -- --reset-cache`.

LESCO_URL=https://bill.pitc.com.pk/lescobill/general?refno={consumer}
FESCO_URL=https://bill.pitc.com.pk/fescobill/general?refno={consumer}
GEPCO_URL=https://bill.pitc.com.pk/gepcobill/general?refno={consumer}
MEPCO_URL=https://bill.pitc.com.pk/mepcobill/general?refno={consumer}
IESCO_URL=https://bill.pitc.com.pk/iescobill/general?refno={consumer}
PESCO_URL=https://bill.pitc.com.pk/pescobill/general?refno={consumer}
HESCO_URL=https://bill.pitc.com.pk/hescobill/general?refno={consumer}
SEPCO_URL=https://bill.pitc.com.pk/sepcobill/general?refno={consumer}
QESCO_URL=https://bill.pitc.com.pk/qescobill/general?refno={consumer}
TESCO_URL=https://bill.pitc.com.pk/tescobill/general?refno={consumer}
KE_URL=https://www.ke.com.pk/bill-information/?account-number={consumer}
OTHER_URL=
